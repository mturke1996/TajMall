{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Taj Mall v2",
  "version": "2.0.0",
  "identifier": "ly.tajmall.fluxen",
  "build": {
    "frontendDist": "https://taj-mall-nu.vercel.app",
    "devUrl": "https://taj-mall-nu.vercel.app",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Taj Mall v2 — Fluxen ERP",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
