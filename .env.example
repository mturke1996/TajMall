# ============================================================
# Fluxen — Local environment (DO NOT COMMIT)
# This file is gitignored (.env.local). Copy it to .env.local and
# fill in REAL values there. Never put real secrets in this file —
# it IS committed to git and may be public.
# ============================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
# New format (preferred if set). Remove or leave empty to use legacy anon JWT below.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxx"
# Legacy anon key (public — safe in browser with RLS). Used if publishable key is unset.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-jwt"

# service_role secret (server-only — NEVER commit, NEVER expose to the browser,
# NEVER put a real value in this .env.example file). Bypasses all RLS.
# Code reads SUPABASE_SECRET_KEY or legacy SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SECRET_KEY="your-service-role-key"

# ---- Database (Prisma — dev-only schema/inspection tool; the live app does
# NOT query through Prisma at runtime, see README) ----
# Supabase → Settings → Database → Connection string
#
# DIRECT_URL — اتصال مباشر. إذا كلمة المرور فيها @ أو # أو : استخدم ترميز URL (%40 بدل @).
# مثال: postgresql://postgres:كلمةالسر_مرمّزة@db.your-project-ref.supabase.co:5432/postgres
# كلمة المرور بدون أقواس مربعة — [PASSWORD] في وثائق Supabase تعني «ضع كلمة المرور هنا» فقط.
DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.your-project-ref.supabase.co:5432/postgres"

# DATABASE_URL — انسخ السلسلة كاملة من Supabase: Connection string → Transaction pooler (أو Session pooler).
# لمنفذ 6543 أضف عادةً: ?pgbouncer=true إن لم يكن في السلسلة المنسوخة.
DATABASE_URL="postgresql://postgres.your-project-ref:YOUR_DB_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ---- App ----
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_NAME="Fluxen"
NEXT_PUBLIC_DEFAULT_LOCALE="ar"
NEXT_PUBLIC_DEFAULT_CURRENCY="LYD"

# ---- Keep-Alive cron auth ----
# Generate a long random string (e.g. `openssl rand -hex 32`). Used by
# /api/keepalive when called manually or from GitHub Actions.
KEEPALIVE_SECRET="generate-a-long-random-string"
