# ============================================================
# Fluxen — Environment variables template
# Copy to .env.local and fill with real values
# ============================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"

# New publishable-key format (recommended, starts with `sb_publishable_…`)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Legacy anon-key format is still supported as a fallback:
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Service-role / secret key — server-only, never expose to the browser.
SUPABASE_SECRET_KEY="sb_secret_..."
# Legacy alternative:
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ---- Database ----
# Prisma uses DATABASE_URL at runtime (constructor in src/lib/prisma.ts).
#
# Prefer "Transaction pooler" for DATABASE_URL (serverless / Vercel). If your network is
# IPv4-only, use Session pooler from Supabase (see Dashboard note on IPv4).
#
# DIRECT_URL optional: direct host for local migrations (`db.PROJECT.supabase.co:5432`).
# Encode special characters in the password inside the URL.
#
# Pooler examples (replace REGION + PASSWORD; copy exact string from Dashboard):
DATABASE_URL="postgresql://postgres.[PROJECT-ref]:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ref].supabase.co:5432/postgres"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Fluxen"
NEXT_PUBLIC_DEFAULT_LOCALE="ar"
NEXT_PUBLIC_DEFAULT_CURRENCY="LYD"

# ---- Keep-Alive (used by /api/keepalive cron) ----
KEEPALIVE_SECRET="generate-a-long-random-string-here"
