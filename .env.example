# ============================================================
# Fluxen — Environment variables template
# Copy to .env.local and fill with real values
# ============================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"

# New publishable-key format (recommended, starts with `sb_publishable_…`)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Legacy anon-key format is still supported as a fallback:
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Service-role / secret key — server-only, never expose to the browser.
SUPABASE_SECRET_KEY="sb_secret_..."
# Legacy alternative:
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ---- Database (Prisma connects via Supabase pooler) ----
DATABASE_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Fluxen"
NEXT_PUBLIC_DEFAULT_LOCALE="ar"
NEXT_PUBLIC_DEFAULT_CURRENCY="LYD"

# ---- Keep-Alive (used by /api/keepalive cron) ----
KEEPALIVE_SECRET="generate-a-long-random-string-here"
