# DATABASE_URL — انسخ السلسلة كاملة من Supabase: Connection string → Transaction pooler (أو Session pooler).
# لمنفذ 6543 أضف عادةً: ?pgbouncer=true إن لم يكن في السلسلة المنسوخة.
DATABASE_URL="postgresql://postgres.xzqcbvyjurbkoniszzbc:Mturke23061996@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

